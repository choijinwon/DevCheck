# Optional: persist scans for shareable /result?scanId=… links
# Leave unset to use sessionStorage only for results.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: wait N ms (0–2000) after DOMContentLoaded before axe (helps some SPAs).
# Counts toward the 10s analysis budget.
# POST_LOAD_DELAY_MS=500

# Rate limit for POST /api/analyze (in-memory per server instance).
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=20

# Optional: use system Chrome/Chromium instead of Puppeteer's download (~/.cache/puppeteer).
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# PUPPETEER_EXECUTABLE_PATH=
